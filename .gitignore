# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# IDEs
.vscode/
.idea/

# ==========================================
# NILM PROJECT SPECIFIC IGNORES
# ==========================================

# 1. Ignore ALL large data file types globally
*.dat
*.flac
*.csv
*.h5
*.npy
*.npz
*.rar
*.zip
*.7z

# 2. Ignore specific data-heavy directories but allow the folder structure
# (We don't use **/Folder/ because it ignores everything inside INCLUDING scripts)

# 3. Specific processed outputs
dataset_preprocess/created_data/

# 4. White-list: ALWAYS keep these files even if they are in data folders
!**/*.py
!**/*.md
!**/*.yaml
!**/*.txt
!**/README.md
!**/.gitignore

# Logs
*.log
